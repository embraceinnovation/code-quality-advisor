# Application
APP_BASE_URL=https://your-app.vercel.app
SECRET_KEY=generate-a-strong-random-secret-here
LOG_LEVEL=INFO
SESSION_TTL_HOURS=8

# Git operations
GIT_CLONE_BASE_DIR=/tmp/cqa
GIT_COMMIT_AUTHOR_NAME=Code Quality Advisor
GIT_COMMIT_AUTHOR_EMAIL=cqa@noreply.local

# Claude AI — optional fallback if no key entered in the UI
# Users can enter their own key in the app
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096
CLAUDE_FILE_SIZE_LIMIT_KB=100
