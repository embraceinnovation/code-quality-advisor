{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ],
  "env": {
    "GIT_CLONE_BASE_DIR": "/tmp/cqa"
  },
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  }
}
